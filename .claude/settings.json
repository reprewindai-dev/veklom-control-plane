{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(npm run typecheck)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run dev:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Edit(.env)",
      "Edit(.env.local)",
      "Write(.env)",
      "Write(.env.local)",
      "Edit(**/*secret*)",
      "Write(**/*secret*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run typecheck"
          },
          {
            "type": "command",
            "command": "npm run lint"
          }
        ]
      }
    ]
  }
}
