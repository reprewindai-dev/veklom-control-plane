# Database
DATABASE_URL="postgresql://username:password@localhost:5432/seked_control_plane"

# Server
PORT=3001
NODE_ENV=development

# CORS Configuration
# Comma-separated list of allowed origins. Use '*' to allow all.
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-here"

# SEKED Configuration
SEKED_SPECIFICATION_VERSION="1.0"
SEKED_CANONICAL_FINGERPRINT="038f8464884a556fbee43972b27cbdfd08d3b522e644c0c644ad1b2ded82fcc7"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL="info"
LOG_FILE="logs/app.log"
